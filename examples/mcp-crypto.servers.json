[
  {
    "command": "npx",
    "args": ["-y", "@mcpdotdirect/evm-mcp-server"],
    "env": {
      "ETHERSCAN_API_KEY": "${ETHERSCAN_API_KEY}",
      "EVM_PRIVATE_KEY": "${EVM_PRIVATE_KEY}"
    }
  },
  {
    "command": "npx",
    "args": ["-y", "mcp-etherscan-server"],
    "env": {
      "ETHERSCAN_API_KEY": "${ETHERSCAN_API_KEY}"
    }
  },
  {
    "command": "npx",
    "args": ["-y", "@coingecko/coingecko-mcp"],
    "env": {
      "COINGECKO_PRO_API_KEY": "${COINGECKO_PRO_API_KEY}",
      "COINGECKO_DEMO_API_KEY": "${COINGECKO_DEMO_API_KEY}",
      "COINGECKO_ENVIRONMENT": "demo"
    }
  },
  {
    "command": "npx",
    "args": ["-y", "solana-mcp-server"],
    "env": {}
  },
  {
    "command": "npx",
    "args": ["-y", "@jamesanz/bitcoin-mcp"],
    "env": {}
  },
  {
    "command": "npx",
    "args": ["-y", "@cryptoapis-io/mcp-contracts"],
    "env": {
      "CRYPTOAPIS_API_KEY": "${CRYPTOAPIS_API_KEY}"
    }
  }
]
