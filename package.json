{
  "name": "@benjam16/umbrella",
  "version": "0.2.2",
  "description": "One CLI + one autonomous agent that does everything: coding, orchestration, tools, memory, security, and more.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Benjam16/Umbrella.git"
  },
  "bugs": {
    "url": "https://github.com/Benjam16/Umbrella/issues"
  },
  "homepage": "https://github.com/Benjam16/Umbrella#readme",
  "main": "dist/src/cli.js",
  "bin": {
    "umbrella": "dist/src/cli.js"
  },
  "files": [
    "dist",
    "bin",
    "modules",
    "runtime",
    "Dockerfile",
    "docker-compose.yml",
    ".dockerignore",
    ".env.umbrella.example",
    "README.md",
    "FEATURES.md",
    "ROADMAP.md",
    "docs",
    "examples",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test tests/plan-replay.test.cjs",
    "dev": "tsx src/cli.ts",
    "install:local": "node bin/install.js --claude --local",
    "agent": "node dist/runtime/index.js",
    "prepublishOnly": "npm run build",
    "publish:npm": "npm publish .",
    "publish:npm:dry": "npm publish --dry-run ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/bolt": "^4.6.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "cron": "^4.4.0",
    "discord.js": "^14.26.2",
    "dotenv": "^16.6.1",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.6",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/cron": "^2.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
