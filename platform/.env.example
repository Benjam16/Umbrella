# API (@umbrella/api) — copy to apps/api/.env

PORT=8787
UMBRELLA_DATA_DIR=./data
UMBRELLA_STARTING_CREDITS=1000
UMBRELLA_ALLOW_DEV_SIGNUP=true
# UMBRELLA_DEFAULT_USER_ROLE=operator
# Optional at-rest encryption for data/store.json
# UMBRELLA_STORE_ENCRYPTION_KEY=replace_with_strong_secret

# Without UMBRELLA_INFERENCE_URL: flat cost per chat (stub echo).
UMBRELLA_CHAT_CREDIT_COST=10

# OpenAI-compatible inference (Ollama, vLLM, NIM, LiteLLM, etc.)
# Ollama: base must include /v1 — then we POST .../chat/completions
UMBRELLA_INFERENCE_URL=http://127.0.0.1:11434/v1
# Model tag must exist in your runtime (ollama pull <name>)
UMBRELLA_INFERENCE_MODEL=gemma3:4b
# Ollama: leave empty or any string; some hosts require a real key
UMBRELLA_INFERENCE_API_KEY=
UMBRELLA_CREDIT_COST_PER_1K_TOKENS=5
# Slow local models: raise if needed (ms)
# UMBRELLA_INFERENCE_TIMEOUT_MS=120000

# Multi-model registry (optional)
# If UMBRELLA_MODEL_IDS is empty, API auto-registers "gemma" from UMBRELLA_INFERENCE_*
# UMBRELLA_DEFAULT_MODEL_ID=gemma
# UMBRELLA_MODEL_IDS=gemma,claude,codex
# UMBRELLA_MODEL_GEMMA_ENABLED=true
# UMBRELLA_MODEL_GEMMA_PROVIDER=openai
# UMBRELLA_MODEL_GEMMA_LABEL=Gemma Hosted
# UMBRELLA_MODEL_GEMMA_BASE_URL=http://127.0.0.1:11434/v1
# UMBRELLA_MODEL_GEMMA_NAME=gemma3:4b
# UMBRELLA_MODEL_GEMMA_API_KEY=
# UMBRELLA_MODEL_GEMMA_CREDITS_PER_1K=5
# UMBRELLA_MODEL_CLAUDE_ENABLED=true
# UMBRELLA_MODEL_CLAUDE_PROVIDER=openai
# UMBRELLA_MODEL_CLAUDE_LABEL=Claude via gateway
# UMBRELLA_MODEL_CLAUDE_BASE_URL=https://your-gateway.example.com/v1
# UMBRELLA_MODEL_CLAUDE_NAME=claude-sonnet
# UMBRELLA_MODEL_CLAUDE_API_KEY=
# UMBRELLA_MODEL_CLAUDE_CREDITS_PER_1K=25

# Run-loop defaults (POST /v1/runs can override per run)
# UMBRELLA_RUN_MAX_STEPS=10
# UMBRELLA_RUN_MAX_MINUTES=30
# UMBRELLA_RUN_MAX_AUTOFIXES=5
# UMBRELLA_RUN_MAX_CREDITS=500
# UMBRELLA_RUN_PROJECT_ROOT=/absolute/path/to/repo
# If set, checkpoints are created in this git repo before execution.
# UMBRELLA_RUN_PROJECT_ROOT=/absolute/path/to/repo
# UMBRELLA_RUN_VERIFY_COMMANDS=npm run -s test,npm run -s build
# UMBRELLA_RUN_ALLOWED_COMMAND_PREFIXES=npm,pnpm,yarn,bun,node,python,pytest,go,cargo
# UMBRELLA_RUN_COMMAND_TIMEOUT_MS=120000
# UMBRELLA_RUN_MAX_OUTPUT_BYTES=32000
# UMBRELLA_RUN_WRITE_ALLOWLIST=src/,apps/,packages/,README.md,platform/
# UMBRELLA_RUN_REQUIRE_APPROVAL_FOR_PROTECTED_WRITES=true
# UMBRELLA_RUN_PROTECTED_PATHS=README.md,package.json,platform/apps/api/src/
# Sandbox preflight for write patches (isolated temp workspace)
# UMBRELLA_SANDBOX_ENABLED=true
# Require verify commands for protected writes in sandbox preflight
# UMBRELLA_SANDBOX_STRICT_PROTECTED=true
# UMBRELLA_RUN_RECOVERY_INTERVAL_MS=15000
# UMBRELLA_SCRAPER_PARALLELISM=2
# UMBRELLA_SUPERVISOR_PARALLELISM=1
# UMBRELLA_CODER_PARALLELISM=1
# UMBRELLA_AUDITOR_PARALLELISM=1
# UMBRELLA_CRO_PARALLELISM=1
# UMBRELLA_RISK_BLOCK_THRESHOLD=7
# Policy decision trail retention
# UMBRELLA_POLICY_DECISION_MAX=10000
# API hardening controls
# UMBRELLA_RATE_LIMIT_PER_MINUTE=240
# UMBRELLA_AUDIT_MAX_EVENTS=20000
# UMBRELLA_AUDIT_CAPTURE_REQUEST_PREVIEW=true
# Outreach/CRM worker
# UMBRELLA_OUTREACH_PARALLELISM=1
# UMBRELLA_OUTREACH_EMAIL_DRY_RUN=true
# UMBRELLA_OUTREACH_LINKEDIN_DRY_RUN=true
# Backup snapshots
# UMBRELLA_BACKUP_ENABLED=true
# UMBRELLA_BACKUP_INTERVAL_MS=900000
# UMBRELLA_BACKUP_RETENTION_COUNT=30
# UMBRELLA_BACKUP_MAX_SNAPSHOTS=120
# UMBRELLA_BACKUP_RESTORE_PREVIEW_TTL_MS=600000
# Optional: enforce periodic backup checksum checks in external jobs.
# Use /v1/backups/verify for on-demand integrity validation.
# UMBRELLA_BACKUP_INTEGRITY_SWEEP_ENABLED=true
# UMBRELLA_BACKUP_INTEGRITY_SWEEP_COUNT=5
# Optional periodic sweep (ms). Set <=0 to disable interval sweeps.
# UMBRELLA_BACKUP_INTEGRITY_INTERVAL_MS=0
# DR health: GET /v1/backups/integrity returns { sweepEnabled, lastSweep } (in-process).
# Memory vault controls (Step #5 thin slice)
# UMBRELLA_MEMORY_MAX_ENTRIES=5000
# UMBRELLA_MEMORY_RETRIEVAL_MODE=hybrid
# UMBRELLA_MEMORY_VECTOR_DIM=128

# Planner / transaction defaults
# UMBRELLA_BASE_CHAIN_ID=8453
# UMBRELLA_DEFAULT_TRANSACTION_TARGET=0x0000000000000000000000000000000000000000
# UMBRELLA_COINBASE_API_KEY=
# UMBRELLA_COINBASE_WALLET_ID=

# MCP servers to auto-connect on API startup (JSON array).
# Example:
# UMBRELLA_MCP_SERVERS=[{"id":"github","command":"npx","args":["-y","@modelcontextprotocol/server-github"]}]

# Observer / scraper (Playwright)
# UMBRELLA_OBSERVER_CHROMIUM_PATH=/absolute/path/to/chromium
# UMBRELLA_OBSERVER_TIMEOUT_MS=30000
# UMBRELLA_OBSERVER_SCROLL_PASSES=4
# UMBRELLA_OBSERVER_DEFAULT_URL=https://example.com
# UMBRELLA_SITE_WATCH_INTERVAL_MS=60000
# Optional global alert fallbacks (used if watch-level values are empty)
# UMBRELLA_ALERT_WEBHOOK_URL=
# UMBRELLA_ALERT_DISCORD_WEBHOOK_URL=
# UMBRELLA_ALERT_TELEGRAM_BOT_TOKEN=
# UMBRELLA_ALERT_TELEGRAM_CHAT_ID=
# Webhook secret for /v1/webhooks/blockchain
# UMBRELLA_WEBHOOK_SECRET=replace_with_strong_random_secret

# Wallet / transaction proposals
# UMBRELLA_BASE_CHAIN_ID=8453
# UMBRELLA_DEFAULT_TRANSACTION_TARGET=0x0000000000000000000000000000000000000000
# UMBRELLA_WALLET_PROVIDER=local
# Set to coinbase_agentkit and provide all secrets below to enable AgentKit runtime.
# UMBRELLA_COINBASE_API_KEY_ID=
# UMBRELLA_COINBASE_API_KEY_SECRET=
# UMBRELLA_COINBASE_WALLET_SECRET=

# Desktop (Vite) — copy to apps/desktop/.env
# VITE_API_URL=http://127.0.0.1:8787

# --- Not wired in code yet ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
