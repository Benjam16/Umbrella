{
  "name": "umbrella-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Umbrella monorepo: web (cloud sandbox), api (local daemon), desktop, and shared packages.",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @umbrella/web dev",
    "dev:api": "pnpm --filter @umbrella/api dev",
    "dev:desktop": "pnpm --filter @umbrella/desktop tauri dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
