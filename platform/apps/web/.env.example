# --- Supabase (Phase 1 backend) -----------------------------------------------
# Required for run persistence, event log, credits_ledger, and registered nodes.
# If either of the first two is missing the app falls back to in-memory runs
# (fine for dev, not fine for production).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
TREASURY_ADDRESS=
BASE_RPC_URL=https://mainnet.base.org
ALCHEMY_WEBHOOK_SIGNING_KEY=
UMBRELLA_FORGE_MIN_PAYMENT_WEI=1100000000000000
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5

# Safe to expose to the browser. Used later when we wire up Supabase Auth and
# the read-only share-link viewer.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Cloud sandbox policy ------------------------------------------------------
# Comma-separated list of additional hostnames the sandbox's http.fetch tool
# may contact. Defaults include wikipedia, github, hn.algolia, reddit,
# stackexchange, httpbin. Subdomains of listed hosts are also allowed.
# Example: UMBRELLA_SANDBOX_ALLOWED_HOSTS=docs.github.com,example.org
UMBRELLA_SANDBOX_ALLOWED_HOSTS=

# --- Remote node bridge (future phase) ----------------------------------------
# The CLI generates this on `umbrella connect`. The website verifies signed
# mission envelopes with this secret. Not required for cloud-only mode.
UMBRELLA_NODE_JWT_SECRET=
