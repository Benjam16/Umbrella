# --- Supabase (Phase 1 backend) -----------------------------------------------
# Required for run persistence, event log, credits_ledger, and registered nodes.
# If either of the first two is missing the app falls back to in-memory runs
# (fine for dev, not fine for production).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
TREASURY_ADDRESS=
TREASURY_ADDRESS_SEPOLIA=
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=
ALCHEMY_WEBHOOK_SIGNING_KEY=
UMBRELLA_FORGE_MIN_PAYMENT_WEI=1100000000000000
UMBRELLA_FORGE_MIN_PAYMENT_WEI_SEPOLIA=1100000000000000
UMBRELLA_FORGE_CHAIN_ID=84532
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5
# When true (default), forge falls back to a local Solidity template if Kimi
# auth is missing/invalid so launches still complete in dev.
UMBRELLA_FORGE_ALLOW_TEMPLATE_FALLBACK=true

# Safe to expose to the browser. Used later when we wire up Supabase Auth and
# the read-only share-link viewer.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Cloud sandbox policy ------------------------------------------------------
# Comma-separated list of additional hostnames the sandbox's http.fetch tool
# may contact. Defaults include wikipedia, github, hn.algolia, reddit,
# stackexchange, httpbin. Subdomains of listed hosts are also allowed.
# Example: UMBRELLA_SANDBOX_ALLOWED_HOSTS=docs.github.com,example.org
UMBRELLA_SANDBOX_ALLOWED_HOSTS=

# --- Remote node bridge (future phase) ----------------------------------------
# The CLI generates this on `umbrella connect`. The website verifies signed
# mission envelopes with this secret. Not required for cloud-only mode.
UMBRELLA_NODE_JWT_SECRET=

# --- Pump.fun-style launch pipeline -------------------------------------------
# Hot wallet used by the deployer service to deploy the per-agent mission
# record and submit createCurveWithPermit. Rotate regularly; keep a
# low-balance alert attached to the address.
# When a creator sets "creator snipe" (initialBuyEth) in Forge, this wallet
# sends that amount as `value` on createCurveWithPermit — it must have snipe
# ETH + gas, not the end user.
UMBRELLA_DEPLOYER_PRIVATE_KEY=
# Deployed factories (Sepolia first, mainnet behind the flag below).
UMBRELLA_AGENT_TOKEN_FACTORY_SEPOLIA=
UMBRELLA_CURVE_FACTORY_SEPOLIA=
UMBRELLA_AGENT_TOKEN_FACTORY_MAINNET=
UMBRELLA_CURVE_FACTORY_MAINNET=
UMBRELLA_V4_POOL_MANAGER_SEPOLIA=0x7da1d65f8b249183667cde74c5cbd46dd38aa829
# In-app v4 WETH/TOKEN swaps for graduated agents (deploy UmbrellaV4SimpleSwap to poolManager above).
NEXT_PUBLIC_UMBRELLA_V4_SWAP_ROUTER_SEPOLIA=
NEXT_PUBLIC_UMBRELLA_V4_SWAP_ROUTER_BASE=
# Bonding curve graduation threshold in wei (default 5 ETH).
UMBRELLA_GRADUATION_THRESHOLD_WEI=5000000000000000000
# Basescan verification (async, non-blocking post-deploy).
BASESCAN_API_KEY=
# Feature flag: flip only after the Sepolia pipeline has been exercised.
UMBRELLA_LAUNCH_MAINNET_ENABLED=false
