{
  "name": "@umbrella/runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared Umbrella runner: blueprint registry, DAG supervisor, allowlisted tools, and the Run/Event types consumed by both the website (cloud sandbox) and the local CLI.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./blueprints": "./src/blueprints.ts",
    "./supervisor": "./src/supervisor.ts",
    "./tools": "./src/tools.ts",
    "./bus": "./src/bus.ts",
    "./supabase": "./src/supabase.ts",
    "./hydrate": "./src/hydrate.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
