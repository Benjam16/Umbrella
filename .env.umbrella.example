# Copy to .env.umbrella and pass to Docker Compose / docker run.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# Slack Socket Mode (!umb …) — all three required:
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_SIGNING_SECRET=...
# UMBRELLA_INBOUND_SECRET=change-me
# External STT: executable path; argv[1]=audio file; stdout=transcript (see docs/VOICE.md)
# UMBRELLA_VOICE_STT=/usr/local/bin/your-stt
# UMBRELLA_VOICE_STT_TIMEOUT_MS=120000
# UMBRELLA_MCP_ENABLED=1
# UMBRELLA_MCP_SERVERS=[{"command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}]
